  <!-- Units module -->
  <h2 id="units-module">Units module</h2>
  <pre><code>from physure import units, get_unit

# Access a unit by name
meter = get_unit("m")
newton = get_unit("N")
pascal = get_unit("Pa")

# Inspect units
print(meter.dimension)  # [length]
print(newton.si_factor) # 1.0 (already SI base)

# CompoundUnit
from physure import CompoundUnit
velocity_unit = CompoundUnit("m/s")</code></pre>

