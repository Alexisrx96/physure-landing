  <!-- Exceptions -->
  <h2 id="exceptions">Exceptions</h2>
  <table>
    <thead><tr><th>Exception</th><th>Raised when</th></tr></thead>
    <tbody>
      <tr><td><code>physureError</code></td><td>Base class for all physure exceptions.</td></tr>
      <tr><td><code>IncompatibleUnitsError</code></td><td>Arithmetic between incompatible dimensions (e.g. adding meters to seconds). This is the primary error for dimension mismatches.</td></tr>
      <tr><td><code>ConversionError</code></td><td>Attempting to convert between incompatible dimensions (e.g. meters to seconds).</td></tr>
      <tr><td><code>UnitNotFoundError</code></td><td>A unit string is not recognized by the system.</td></tr>
      <tr><td><code>UnknownUnitError</code></td><td>Unit expression could not be parsed; includes spelling suggestions.</td></tr>
      <tr><td><code>DimensionError</code></td><td>Invalid operation on dimensions (base class, may be raised in edge cases).</td></tr>
    </tbody>
  </table>
  <div class="callout callout-warning">
    <p><strong>Note:</strong> The error raised when adding incompatible units (e.g. <code>Q_(10, "m") + Q_(5, "s")</code>) is <code>IncompatibleUnitsError</code>, not <code>DimensionError</code>. Both are exported from <code>physure</code>.</p>
  </div>
  <pre><code>from physure import Q_, ConversionError, IncompatibleUnitsError

try:
    Q_(10, "m").to("s")   # length → time: invalid conversion
except ConversionError as e:
    print(f"Conversion error: &#123;e&#125;")

try:
    Q_(10, "m") + Q_(5, "s")  # incompatible add
except IncompatibleUnitsError as e:
    print(f"Incompatible units: &#123;e&#125;")</code></pre>

