---
import DocsLayout from "../layouts/DocsLayout.astro";
import docstrings from "../data/api-docstrings.json";

const api = [
  {
    name: "Q_",
    signature: "Q_(value, unit, uncertainty=None)",
    desc: "The main factory for creating Quantity objects. Returns a Quantity with the given value and unit string.",
    params: [
      { name: "value", type: "float | int | np.ndarray | torch.Tensor | jax.Array", desc: "The numeric value." },
      { name: "unit", type: "str", desc: "Unit expression string, e.g. 'm/s', 'kg*m^2/s^2', 'degC'." },
      { name: "uncertainty", type: "float | None", desc: "Optional standard deviation (1σ) of the measurement." },
    ],
    returns: "Quantity",
    example: `from physure import Q_\n\nv = Q_(10, "m/s")\nF = Q_(9.81, "m/s^2", uncertainty=0.02)`
  },
  {
    name: "Quantity",
    signature: "class Quantity",
    desc: "The core class representing a physical quantity — a value with a unit and optional uncertainty.",
    params: [],
    returns: null,
    example: `from physure import Quantity\n\nq = Quantity.from_input(10, "m")\nprint(q.magnitude)  # 10.0\nprint(q.unit)       # Unit("m")\nprint(q.dimension)  # [length]`,
    methods: [
      { name: ".to(unit_str)", desc: "Returns a new Quantity converted to the given unit." },
      { name: ".ito(unit_str)", desc: "Does not exist in the library. Use q = q.to(unit_str) instead." },
      { name: ".to_base()", desc: "Converts to the SI base unit representation." },
      { name: ".diff(variable)", desc: "Symbolic differentiation (requires [symbolic] extra)." },
      { name: ".magnitude", desc: "Raw numeric value (always a float/array, never a Quantity)." },
      { name: ".m", desc: "Shorthand alias for .magnitude (pint-compatible)." },
      { name: ".unit", desc: "The Unit object attached to this Quantity." },
      { name: ".uncertainty", desc: "The standard deviation (or Uncertainty object) if set." },
      { name: ".dimension", desc: "The dimensional signature, e.g. [length²]." },
    ]
  },
  {
    name: "Uncertainty",
    signature: "class Uncertainty",
    desc: "Represents measurement uncertainty. Wraps a standard deviation value and tracks covariance for correlated propagation.",
    params: [],
    returns: null,
    example: `from physure import Uncertainty\n\nunc = Uncertainty(0.05)  # ± 0.05\nq = Q_(9.81, "m/s^2", uncertainty=unc)`,
    methods: [
      { name: ".std_dev", desc: "Standard deviation value." },
      { name: ".variance", desc: "Variance (std_dev²)." },
    ]
  },
];

const functions = [
  { name: "get_current_system()", module: "physure", desc: "Returns the active UnitSystem." },
  { name: "get_unit(expr)", module: "physure", desc: "Parses and returns a Unit object from an expression string." },
  { name: "propagation_mode(mode)", module: "physure", desc: "Context manager to switch between 'independent' and 'correlated' uncertainty propagation." },
  { name: "uncertainty_mode(mode)", module: "physure", desc: "Context manager for uncertainty computation strategy." },
  { name: "system_context(system)", module: "physure", desc: "Context manager to use a custom UnitSystem." },
  { name: "create_system(**kwargs)", module: "physure", desc: "Creates a custom UnitSystem with specified units." },
  { name: "create_default_system()", module: "physure", desc: "Creates and returns the default SI-based UnitSystem." },
  { name: "save_state(path, quantities)", module: "physure", desc: "Serializes quantities to disk (requires [io] extra)." },
  { name: "load_state(path)", module: "physure", desc: "Deserializes quantities from disk (requires [io] extra)." },
  { name: "jit(fn)", module: "physure", desc: "Decorator/function to JIT-compile a unit-aware function." },
];

const grammarApi = [
  { syntax: "name = value unit", desc: "Assign a quantity. Also accepts name -> value unit." },
  { syntax: "expr => unit", desc: "Convert expression to target unit and print." },
  { syntax: "expr == value unit", desc: "Assert equality (prints True/False)." },
  { syntax: "name = ?", desc: "Query the current value of a variable." },
  { syntax: "value +/- unc unit", desc: "Quantity literal with uncertainty." },
  { syntax: "# comment", desc: "Line comment." },
];
---

