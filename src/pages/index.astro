---
// ponytail: single-page site, everything inline — split into a Layout when page #2 exists.
const SITE = Astro.site?.href.replace(/\/$/, "") ?? "";
const TITLE = "MeasureKit — Unit-aware physics computation for Python";
const DESCRIPTION =
  "Python library for physical units, dimensional analysis, and uncertainty propagation. Zero runtime dependencies, optional Rust core, NumPy/PyTorch/JAX backends, JIT-compiled unit checks. MIT licensed.";
const OG_IMAGE = SITE + "/logo.jpg";

const faqs = [
  {
    q: "Is MeasureKit fast?",
    a: "It depends on how you use it. In eager mode (plain Python), creating Quantity objects is significantly slower than raw floats or tensors — sometimes 10–100× overhead. In compiled mode (torch.compile or jax.jit), unit checks happen at trace time and the compiled graph sees only raw tensors, measured at under 1.1× overhead versus raw PyTorch. If you need raw speed, compile. If you're validating unit consistency in data processing, eager mode is fine.",
  },
  {
    q: "Should I use MeasureKit instead of Pint?",
    a: "Maybe not. Pint is mature, widely adopted, and well documented — if you need a battle-tested general-purpose unit library, start there. MeasureKit is a younger project (beta) that exists for specific needs: JIT-compiled unit safety on PyTorch/JAX tensors, correlated uncertainty propagation with a full covariance store, and a zero-dependency install.",
  },
  {
    q: "Does MeasureKit require Rust?",
    a: "No. The Rust core (measurekit-core) is an optional extra — pip install \"measurekit[native]\". Every Rust-accelerated code path has a pure-Python fallback, so the base install has zero runtime dependencies and works everywhere Python 3.10+ runs.",
  },
  {
    q: "Does it handle measurement uncertainty?",
    a: "Yes. Quantities can carry uncertainties, written as literals like 9.81 +/- 0.02 m/s^2. Propagation supports two modes: uncorrelated (fast, independent errors) and correlated, which tracks a full covariance matrix across quantities so correlated errors cancel correctly instead of being double-counted.",
  },
  {
    q: "Can I use it without writing Python?",
    a: "Yes. python -m measurekit \"500 N / 2 m^2 => kPa\" evaluates a single expression from the shell, and running it with no arguments opens an interactive REPL — like GNU units, but with uncertainty propagation. First evaluation takes about half a second.",
  },
  {
    q: "What units and constants are included?",
    a: "125+ units across 28 dimensions with 24 SI prefixes, plus 400+ physical constants from CODATA 2022. The full list is generated from the unit definitions and published in the repository at docs/UNITS.md.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      name: "MeasureKit",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "OS Independent",
      description: DESCRIPTION,
      license: "https://opensource.org/license/mit",
      programmingLanguage: "Python",
      softwareRequirements: "Python >= 3.10",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      downloadUrl: "https://pypi.org/project/measurekit/",
      codeRepository: "https://github.com/Alexisrx96/measurekit",
      author: { "@type": "Person", name: "Irvin Torres" },
    },
    {
      "@type": "FAQPage",
      mainEntity: faqs.map(({ q, a }) => ({
        "@type": "Question",
        name: q,
        acceptedAnswer: { "@type": "Answer", text: a },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href={SITE + "/"} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content={SITE + "/"} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={OG_IMAGE} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <header class="hero">
      <img class="logo" src="/logo.jpg" alt="MeasureKit logo: an M shaped like a caliper and a K shaped like a snake" width="512" height="512" />
      <p class="kicker">Python · MIT · Zero runtime dependencies</p>
      <h1>MeasureKit</h1>
      <p class="tagline">
        Unit-aware physics computation for Python — dimensional analysis,
        uncertainty propagation, and tensor backends, with honest performance
        numbers.
      </p>
      <pre class="install"><code>pip install measurekit</code></pre>
      <nav class="cta">
        <a class="btn primary" href="https://github.com/Alexisrx96/measurekit">GitHub</a>
        <a class="btn" href="https://pypi.org/project/measurekit/">PyPI</a>
        <a class="btn" href="https://github.com/Alexisrx96/measurekit/blob/main/docs/UNITS.md">Unit reference</a>
      </nav>
    </header>

    <main>
      <section aria-labelledby="what">
        <h2 id="what">What it does</h2>
        <p>
          MeasureKit attaches physical units to numbers, NumPy arrays, PyTorch
          tensors, and JAX arrays, and refuses to let you add meters to
          seconds. Quantities carry their units and uncertainties through
          arithmetic, conversions, and — if you want — JIT compilation.
        </p>
        <pre><code>from measurekit import Q_

d = Q_(10, "km")
t = Q_(2, "hr")
v = d / t

print(v.to("m/s"))   # 1.3888888888888888 m/s
d + t                # raises: length + time is not a thing</code></pre>
        <p>
          It also works straight from the terminal, with uncertainty literals —
          like GNU <code>units</code>, but with error propagation:
        </p>
        <pre><code>$ python -m measurekit "500 N / 2 m^2 =&gt; kPa"
0.25 kPa

$ python -m measurekit
mk&gt; g = 9.81 +/- 0.02 m/s^2
mk&gt; g =&gt; ft/s^2</code></pre>
      </section>

      <section aria-labelledby="honest">
        <h2 id="honest">The honest performance section</h2>
        <p>
          Most unit libraries claim "zero overhead". Here is what that actually
          means in MeasureKit, measured, no cherry-picking:
        </p>
        <ul>
          <li>
            <strong>Eager mode (plain Python) is slow.</strong> Creating a
            <code>Quantity</code> allocates Python objects and validates units
            — sometimes 10–100× slower than raw floats or tensors. Do not put
            it in a hot loop and expect miracles.
          </li>
          <li>
            <strong>Compiled mode is where the claim is real.</strong> Under
            <code>torch.compile</code> or <code>jax.jit</code>, MeasureKit uses
            <code>__torch_dispatch__</code> to validate units during tracing
            and then strips the abstraction away. The compiled graph sees only
            raw tensors: measured at <strong>under 1.1× overhead</strong> vs
            pure PyTorch. Trade-off: unit checks happen at compile time, so
            dynamically changing units at runtime bypasses them.
          </li>
          <li>
            <strong>The optional Rust core helps, but crossing the
            Python–Rust boundary isn't free.</strong> It speeds up eager-mode
            scalars; it does not make Python fast.
          </li>
          <li>
            <strong>First use is ~0.5 s</strong> — import plus the first
            evaluated expression, without pulling in torch or scipy. This is a
            tracked performance budget in CI, not an aspiration.
          </li>
        </ul>
      </section>

      <section aria-labelledby="features">
        <h2 id="features">Features</h2>
        <dl class="features">
          <div>
            <dt>Multi-backend tensors</dt>
            <dd>
              NumPy, PyTorch, and JAX backends, selected automatically from the
              value you pass in. Each is an optional extra with a lazy import.
            </dd>
          </div>
          <div>
            <dt>Correlated uncertainty propagation</dt>
            <dd>
              Beyond independent-error propagation: a sparse covariance store
              tracks correlations between quantities, so <code>x - x</code>
              is exactly zero ± zero.
            </dd>
          </div>
          <div>
            <dt>JIT-compiled unit safety</dt>
            <dd>
              Unit arithmetic is validated symbolically at trace time; the
              compiled kernel runs on raw tensors with no unit machinery left.
            </dd>
          </div>
          <div>
            <dt>Optional Rust core</dt>
            <dd>
              <code>measurekit-core</code> (PyO3) accelerates unit algebra and
              the covariance store. Every path has a pure-Python fallback.
            </dd>
          </div>
          <div>
            <dt>Notation grammar &amp; REPL</dt>
            <dd>
              Write physics like on paper — <code>force = 500 N</code>,
              <code>stress =&gt; kPa</code>, <code>stress == 250 Pa</code> —
              in Python, in files, or interactively.
            </dd>
          </div>
          <div>
            <dt>Static typing support</dt>
            <dd>
              A mypy plugin narrows <code>Q_(v, "m/s")</code> to a unit-aware
              literal type at analysis time. Optional pandas, pydantic, and
              sympy integrations.
            </dd>
          </div>
        </dl>
      </section>

      <section aria-labelledby="numbers">
        <h2 id="numbers">By the numbers</h2>
        <ul class="stats">
          <li><strong>0</strong> runtime dependencies in the base install</li>
          <li><strong>125+</strong> units across <strong>28</strong> dimensions</li>
          <li><strong>400+</strong> CODATA 2022 physical constants</li>
          <li><strong>24</strong> SI prefixes</li>
          <li><strong>Python 3.10–3.12</strong>, tested on all three in CI</li>
          <li><strong>80%+</strong> test coverage, enforced as a CI gate</li>
        </ul>
      </section>

      <section aria-labelledby="faq">
        <h2 id="faq">Questions people actually ask</h2>
        {faqs.map(({ q, a }) => (
          <details>
            <summary><h3>{q}</h3></summary>
            <p>{a}</p>
          </details>
        ))}
      </section>

      <section aria-labelledby="origin">
        <h2 id="origin">Where this came from</h2>
        <p>
          MeasureKit started as a homework validator: one developer wanted to
          check physics exercises and, instead of adding two numbers, built a
          backend-agnostic, JIT-compilable dimension engine. It is a one-person
          project (plus AI), open source under MIT, and it says so out loud —
          the README calls itself "The Over-Engineered Homework Validator".
          What you get from that: an author who documents the slow paths as
          carefully as the fast ones.
        </p>
      </section>
    </main>

    <footer>
      <p>
        <a href="https://github.com/Alexisrx96/measurekit">Source on GitHub</a> ·
        <a href="https://pypi.org/project/measurekit/">measurekit on PyPI</a> ·
        <a href="https://pypi.org/project/measurekit-core/">measurekit-core on PyPI</a> ·
        MIT License · Built by Irvin Torres
      </p>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #0d1117;
    --panel: #161b22;
    --text: #e6edf3;
    --muted: #9198a1;
    --accent: #58a6ff;
    --border: #30363d;
    color-scheme: dark;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font: 17px/1.65 system-ui, -apple-system, "Segoe UI", sans-serif;
  }
  .hero,
  main,
  footer {
    max-width: 44rem;
    margin-inline: auto;
    padding: 1.5rem;
  }
  .hero {
    padding-block: 4rem 2rem;
    text-align: center;
  }
  .logo {
    width: 9.5rem;
    height: auto;
    border-radius: 20px;
    border: 1px solid var(--border);
  }
  .kicker {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8rem;
  }
  h1 {
    font-size: 3rem;
    margin: 0.25rem 0;
  }
  .tagline {
    font-size: 1.2rem;
    color: var(--muted);
    max-width: 36rem;
    margin-inline: auto;
  }
  .install {
    display: inline-block;
    padding: 0.6rem 1.4rem;
    font-size: 1.1rem;
  }
  .cta {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    padding: 0.5rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    text-decoration: none;
  }
  .btn.primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #0d1117;
    font-weight: 600;
  }
  .btn:hover {
    border-color: var(--accent);
  }
  section {
    margin-block: 3.5rem;
  }
  h2 {
    font-size: 1.6rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.4rem;
  }
  a {
    color: var(--accent);
  }
  pre {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.9rem;
  }
  code {
    font-family: ui-monospace, "Cascadia Code", Menlo, monospace;
  }
  p code,
  li code,
  dd code {
    background: var(--panel);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1rem;
    margin: 0;
  }
  .features > div {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
  }
  dt {
    font-weight: 600;
    margin-bottom: 0.3rem;
  }
  dd {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .stats {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 0.75rem;
  }
  .stats li {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
  }
  .stats strong {
    color: var(--accent);
  }
  details {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
    background: var(--panel);
  }
  summary {
    cursor: pointer;
  }
  summary h3 {
    display: inline;
    font-size: 1.05rem;
    margin: 0;
  }
  details p {
    color: var(--muted);
  }
  footer {
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.9rem;
    text-align: center;
    margin-top: 3rem;
  }
</style>
