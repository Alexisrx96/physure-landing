  <!-- Section: Basic Physics -->
  <section class="example-section">
    <div class="example-header">
      <span class="example-icon">🎓</span>
      <div style="flex: 1;">
        <h2 id="homework">Validador de Tareas — Cinemática</h2>
        <p>El caso de uso original: verificar problemas físicos con seguridad de unidades.</p>
      </div>
      <a href="/es/playground" class="btn-secondary run-in-playground" style="font-size: 0.8rem; padding: 0.35rem 0.75rem; border-radius: 6px; flex-shrink: 0; align-self: center; text-decoration: none;">Probar en Playground 🚀</a></div>
    <pre><code>from physure import Q_

# Problema: Un auto viaja a 90 km/h. ¿Qué distancia recorre en 2.5 horas?
velocidad = Q_(90, "km/hr")
tiempo    = Q_(2.5, "hr")
distancia = velocidad * tiempo

print(f"Distancia: &#123;distancia&#125;")            # 225.0 km
print(f"En metros: &#123;distancia.to('m')&#125;")   # 225000.0 m
print(f"En millas: &#123;distancia.to('mi')&#125;")   # 139.81 mi

# Problema: Convertir 60 mi/hr a m/s
v = Q_(60, "mi/hr")
print(f"60 mi/hr = &#123;v.to('m/s'):.2f&#125;")     # 26.82 m/s

# Problema: Caída libre — ¿qué distancia cae un cuerpo en 3 segundos?
g = Q_(9.81, "m/s^2")
t = Q_(3.0, "s")

# d = ½ × g × t²
d = 0.5 * g * t**2
print(f"Caída libre: &#123;d&#125;")    # 44.145 m</code></pre>
  </section>

  <!-- Section: Force & Pressure -->
  <section class="example-section">
    <div class="example-header">
      <span class="example-icon">⚙️</span>
      <div style="flex: 1;">
        <h2 id="engineering">Ingeniería: Fuerza y Presión</h2>
        <p>Análisis de esfuerzo y cálculos de presión hidráulica.</p>
      </div>
      <a href="/es/playground" class="btn-secondary run-in-playground" style="font-size: 0.8rem; padding: 0.35rem 0.75rem; border-radius: 6px; flex-shrink: 0; align-self: center; text-decoration: none;">Probar en Playground 🚀</a></div>
    <pre><code>from physure import Q_

# Cálculo de esfuerzo axial
force = Q_(500, "N")
area  = Q_(2.0, "m^2")
stress = force / area

print(stress)             # 250.0 Pa
print(stress.to("kPa"))   # 0.25 kPa
print(stress.to("psi"))   # 0.0363 psi

# Presión hidráulica
flow_rate = Q_(10, "L/min")
head_loss = Q_(5, "bar")

# Potencia = Caudal × Caída de presión
power = flow_rate.to("m^3/s") * head_loss.to("Pa")
print(f"Potencia hidráulica: &#123;power.to('W'):.1f&#125;")  # ~833.3 W

# Momento de inercia
m = Q_(2.0, "kg")
r = Q_(0.3, "m")
I = m * r**2
print(I)                # 0.18 kg⋅m²
print(I.to("g⋅cm^2"))   # 1.8e+6 g⋅cm²</code></pre>
  </section>

  <!-- Section: Temperature -->
  <section class="example-section">
    <div class="example-header">
      <span class="example-icon">🌡️</span>
      <div style="flex: 1;">
        <h2 id="temperature">Conversiones de Temperatura</h2>
        <p>Manejo de unidades con desplazamiento (Celsius, Fahrenheit, Kelvin).</p>
      </div>
      <a href="/es/playground" class="btn-secondary run-in-playground" style="font-size: 0.8rem; padding: 0.35rem 0.75rem; border-radius: 6px; flex-shrink: 0; align-self: center; text-decoration: none;">Probar en Playground 🚀</a></div>
    <pre><code>from physure import Q_

# Conversiones absolutas
t_c = Q_(100, "degC")
print(t_c.to("degF"))  # 212.0 °F
print(t_c.to("K"))     # 373.15 K

t_f = Q_(32, "degF")
print(t_f.to("degC"))  # 0.0 °C
print(t_f.to("K"))     # 273.15 K

# DIFERENCIA de temperatura (lineal — sin desplazamiento de origen)
t1 = Q_(100, "degC")
t2 = Q_(90,  "degC")
delta = t1 - t2          # Diferencia de temperatura
print(delta)             # 10 K (o ΔdegC)
print(delta.to("K"))     # 10.0 K

# Sumar un delta a una temperatura absoluta
t_new = t1 + Q_(5, "K")  # 105.0 °C</code></pre>
  </section>

  <!-- Section: Uncertainty -->
  <section class="example-section">
    <div class="example-header">
      <span class="example-icon">📊</span>
      <div style="flex: 1;">
        <h2 id="uncertainty">Propagación de Incertidumbre</h2>
        <p>Cálculo del margen de error para experimentos de física.</p>
      </div>
      <a href="/es/playground" class="btn-secondary run-in-playground" style="font-size: 0.8rem; padding: 0.35rem 0.75rem; border-radius: 6px; flex-shrink: 0; align-self: center; text-decoration: none;">Probar en Playground 🚀</a></div>
    <pre><code>from physure import Q_
import math

# Medir la gravedad de un experimento de péndulo
# T = 2π√(L/g)  →  g = 4π²L/T²

L = Q_(1.0,  "m", uncertainty=0.002)   # 1.000 ± 0.002 m
T = Q_(2.01, "s", uncertainty=0.005)   # 2.01  ± 0.005 s

g_meas = 4 * math.pi**2 * L / T**2
print(f"g = &#123;g_meas.magnitude:.4f&#125; ± &#123;g_meas.uncertainty:.4f&#125; m/s²")
# g = 9.7892 ± 0.0518 m/s²

# Error relativo
rel_error = g_meas.uncertainty / g_meas.magnitude * 100
print(f"Error relativo: &#123;rel_error:.2f&#125;%")  # ~0.53%

# Resistencia a partir de la ley de Ohm: R = V/I
V = Q_(12.0, "V",  uncertainty=0.1)
I = Q_(2.5,  "A",  uncertainty=0.05)
R = V / I
print(f"R = &#123;R.magnitude:.3f&#125; ± &#123;R.uncertainty:.3f&#125; Ω")  # 4.800 ± 0.124 Ω</code></pre>
  </section>

  <!-- Section: Grammar -->
  <section class="example-section">
    <div class="example-header">
      <span class="example-icon">✍️</span>
      <div style="flex: 1;">
        <h2 id="grammar">Notación de Gramática</h2>
        <p>Escribe cálculos en notación física natural utilizando GrammarInterpreter.</p>
      </div>
      <a href="/es/playground" class="btn-secondary run-in-playground" style="font-size: 0.8rem; padding: 0.35rem 0.75rem; border-radius: 6px; flex-shrink: 0; align-self: center; text-decoration: none;">Probar en Playground 🚀</a></div>
    <pre><code>from physure.ext.grammar import GrammarInterpreter

mn = GrammarInterpreter()

# Resolver varias variables interconectadas
mn.run("""
# Análisis de circuito eléctrico
V    = 24 V
R1   = 100 Ω
R2   = 200 Ω
I    = V / R1
P    = V * I
""")

# Consultar valores convertidos
print(mn.eval("I => mA"))      # 240.0 mA
print(mn.eval("P => W"))       # 5.76 W

# Aseveraciones para validar resultados
print(mn.eval("I == 0.24 A"))  # True
print(mn.eval("P == 5.76 W"))  # True</code></pre>
