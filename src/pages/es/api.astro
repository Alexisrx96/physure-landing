  <h3>Ejemplo de propagation_mode</h3>
  <pre><code>import physure as mk
from physure import Q_

# Por defecto el modo es 'correlated' — x - x = 0 exactamente
x = Q_(5.0, "m", uncertainty=0.1)
delta = x - x
print(delta.uncertainty)   # ~0.0  (cancelación de correlación)

# Alternar a modo no correlacionado
with mk.propagation_mode("uncorrelated"):
    delta2 = x - x   # 0.0 ± 0.141 m  (los errores se suman en cuadratura)

# Otros modos: "monte_carlo", "unscented"
with mk.propagation_mode("monte_carlo"):
    ...</code></pre>

