---
import DocsLayout from "../../layouts/DocsLayout.astro";
import docstrings from "../../data/api-docstrings.json";

const api = [
  {
    name: "Q_",
    signature: "Q_(value, unit, uncertainty=None)",
    desc: "La factoría principal para crear objetos Quantity. Devuelve un objeto Quantity a partir de un valor numérico y una cadena de texto de unidad.",
    params: [
      { name: "value", type: "float | int | np.ndarray | torch.Tensor | jax.Array", desc: "El valor numérico." },
      { name: "unit", type: "str", desc: "La cadena de texto que describe la unidad física, ej. 'm/s', 'kg*m^2/s^2', 'degC'." },
      { name: "uncertainty", type: "float | None", desc: "Desviación estándar opcional (1σ) de la medición." },
    ],
    returns: "Quantity",
    example: `from physure import Q_\n\nv = Q_(10, "m/s")\nF = Q_(9.81, "m/s^2", uncertainty=0.02)`
  },
  {
    name: "Quantity",
    signature: "class Quantity",
    desc: "La clase central que representa una cantidad física — un valor numérico con una unidad asociada e incertidumbre opcional.",
    params: [],
    returns: null,
    example: `from physure import Quantity\n\nq = Quantity.from_input(10, "m")\nprint(q.magnitude) # 10.0\nprint(q.unit)      # Unit("m")\nprint(q.dimension) # [length]`,
    methods: [
      { name: ".to(unit_str)", desc: "Devuelve una nueva Quantity convertida a la unidad indicada." },
      { name: ".ito(unit_str)", desc: "No existe en la librería. Usa q = q.to(unit_str) en su lugar." },
      { name: ".to_base()", desc: "Devuelve una nueva Quantity en unidades base del SI (m, kg, s, A, K, mol, cd)." },
      { name: ".diff(variable)", desc: "Diferenciación simbólica (requiere el extra [symbolic])." },
      { name: ".magnitude", desc: "El valor numérico neto (flotante o tensor, nunca una Quantity)." },
      { name: ".m", desc: "Alias para .magnitude (soportado por compatibilidad con Pint)." },
      { name: ".unit", desc: "El objeto CompoundUnit asociado a esta Quantity." },
      { name: ".u", desc: "Alias para .unit." },
      { name: ".uncertainty", desc: "La desviación estándar de la incertidumbre." },
      { name: ".dimension", desc: "La dimensión física (ej. [length²])." },
    ]
  },
  {
    name: "Uncertainty",
    signature: "class Uncertainty",
    desc: "Clase base abstracta para modelos de incertidumbre. En la práctica, pasas un float al parámetro uncertainty de Q_ y physure lo envuelve automáticamente.",
    params: [],
    returns: null,
    example: `from physure import Q_\n\nq = Q_(9.81, "m/s^2", uncertainty=0.02)\nprint(q.uncertainty) # 0.02`,
    methods: [
      { name: ".std_dev", desc: "La desviación estándar (1σ)." },
      { name: ".variance", desc: "La varianza (desv_est²)." },
    ]
  },
];

const functions = [
  { name: "get_current_system()", module: "physure", desc: "Devuelve el UnitSystem activo." },
  { name: "get_unit(expr)", module: "physure", desc: "Analiza y devuelve un objeto Unit a partir de una cadena." },
  { name: "propagation_mode(mode)", module: "physure", desc: "Gestor de contexto para alternar modos de propagación de covarianza: 'correlated' (por defecto), 'uncorrelated', etc." },
  { name: "uncertainty_mode(mode)", module: "physure", desc: "Gestor de contexto para configurar el backend de cálculo de incertidumbres ('python', 'monte_carlo', 'unscented')." },
  { name: "system_context(system)", module: "physure", desc: "Gestor de contexto para usar un UnitSystem personalizado (con alias use_system)." },
  { name: "create_system(config)", module: "physure", desc: "Crea un UnitSystem a partir de un archivo de configuración (ej. 'imperial.conf')." },
  { name: "create_default_system()", module: "physure", desc: "Crea y devuelve el UnitSystem por defecto (SI)." },
  { name: "save_state(path, quantities)", module: "physure", desc: "Serializa el estado del CovarianceStore de la aplicación (requiere extra [io])." },
  { name: "load_state(path)", module: "physure", desc: "Deserializa y restaura el estado del CovarianceStore (requiere extra [io])." },
  { name: "jit(fn)", module: "physure", desc: "Decorador/función para compilar JIT una función física." },
];

const grammarApi = [
  { syntax: "nombre = valor unidad", desc: "Asignación de variable. También se acepta nombre -> valor unidad." },
  { syntax: "expr => unidad", desc: "Conversión de unidad de la expresión en tiempo de evaluación." },
  { syntax: "expr == valor unidad", desc: "Aseveración (retorna True o False)." },
  { syntax: "nombre = ?", desc: "Consulta el valor actual e incertidumbre de la variable." },
  { syntax: "valor +/- inc unidad", desc: "Literal de cantidad con incertidumbre." },
  { syntax: "# comentario", desc: "Comentario de línea." },
];
