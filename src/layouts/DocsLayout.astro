---
export interface Props {
  title: string;
  description?: string;
  activeSection?: string;
}

const { title, description = "physure — Unit-aware physics computation for Python", activeSection = "" } = Astro.props;

const SITE = Astro.site?.href.replace(/\/$/, "") ?? "";
const OG_IMAGE = SITE + "/logo.jpg";

// Multi-language detection
const isSpanish = Astro.url.pathname.startsWith("/es");
const lang = isSpanish ? "es" : "en";
const langPrefix = isSpanish ? "/es" : "";

// Generate paths for both languages
const currentPath = Astro.url.pathname;
const enPath = isSpanish 
  ? (currentPath.replace(/^\/es/, "") || "/") 
  : currentPath;
const esPath = isSpanish 
  ? currentPath 
  : (`/es${currentPath === "/" ? "" : currentPath}`);

const navItems = [
  { label: isSpanish ? "Inicio" : "Overview", href: `${langPrefix}/`, section: "overview", icon: "🏠" },
  { label: isSpanish ? "Instalación" : "Installation", href: `${langPrefix}/install`, section: "install", icon: "📦" },
  { label: isSpanish ? "Guía Rápida" : "Quick Start", href: `${langPrefix}/quickstart`, section: "quickstart", icon: "⚡" },
  { label: isSpanish ? "Guía de Usuario" : "User Guide", href: `${langPrefix}/guide`, section: "guide", icon: "📖" },
  { label: isSpanish ? "Referencia API" : "API Reference", href: `${langPrefix}/api`, section: "api", icon: "🔧" },
  { label: isSpanish ? "Ejemplos" : "Examples", href: `${langPrefix}/examples`, section: "examples", icon: "🧪" },
  { label: isSpanish ? "Tutoriales" : "Tutorials", href: `${langPrefix}/tutorials`, section: "tutorials", icon: "📚" },
  { label: isSpanish ? "Playground" : "Playground", href: `${langPrefix}/playground`, section: "playground", icon: "🚀" },
  { label: isSpanish ? "CLI y REPL" : "CLI & REPL", href: `${langPrefix}/cli`, section: "cli", icon: "💻" },
  { label: isSpanish ? "Extensión VS Code" : "VS Code Extension", href: `${langPrefix}/vscode`, section: "vscode", icon: "🔌" },
  { label: isSpanish ? "Historial" : "Changelog", href: `${langPrefix}/changelog`, section: "changelog", icon: "📋" },
];

// Layout Translations
const t = {
  navigation: isSpanish ? "Navegación" : "Navigation",
  install: isSpanish ? "Instalación" : "Install",
  stats: isSpanish ? "Estadísticas" : "Stats",
  license: isSpanish ? "Licencia" : "License",
  python: "Python",
  version: isSpanish ? "Versión" : "Version",
  status: isSpanish ? "Estado" : "Status",
  deps: "Deps",
  copy: isSpanish ? "Copiar" : "Copy",
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — physure Docs</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={SITE + Astro.url.pathname} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title + " — physure Docs"} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={SITE + Astro.url.pathname} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta name="twitter:card" content="summary" />
  </head>

  <body>
    <!-- Top Navigation Bar -->
    <header class="topbar">
      <div class="topbar-inner">
        <a href={langPrefix + "/"} class="brand">
          <img src="/logo.jpg" alt="physure" width="32" height="32" class="brand-logo" />
          <span class="brand-name">physure</span>
          <span class="brand-badge">v0.1.8</span>
        </a>
        <button class="search-trigger" id="searchTrigger" title={isSpanish ? "Buscar en la documentación" : "Search documentation"}>
          <span>🔍 {isSpanish ? "Buscar..." : "Search..."}</span>
          <kbd class="search-kbd">Ctrl K</kbd>
        </button>
        <nav class="topbar-nav">
          <div class="lang-selector" title={isSpanish ? "Seleccionar idioma" : "Select language"}>
            <span class="lang-globe">🌐</span>
            <a href={enPath} class={`lang-btn ${!isSpanish ? 'active' : ''}`} aria-current={!isSpanish ? "page" : undefined}>EN</a>
            <a href={esPath} class={`lang-btn ${isSpanish ? 'active' : ''}`} aria-current={isSpanish ? "page" : undefined}>ES</a>
          </div>
          <a href="https://github.com/Alexisrx96/physure" target="_blank" rel="noopener" class="topbar-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="https://pypi.org/project/physure/" target="_blank" rel="noopener" class="topbar-link">PyPI</a>
        </nav>
        <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu">☰</button>
      </div>
    </header>

    <div class="layout">
      <!-- Sidebar -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-inner">
          <div class="sidebar-section">
            <p class="sidebar-label">{t.navigation}</p>
            <ul class="sidebar-nav">
              {navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class={`sidebar-link ${activeSection === item.section ? "active" : ""}`}
                  >
                    <span class="nav-icon">{item.icon}</span>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class="sidebar-section">
            <p class="sidebar-label">{t.install}</p>
            <div class="install-box">
              <code>pip install physure</code>
              <button class="copy-btn" data-copy="pip install physure" title={t.copy}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              </button>
            </div>
          </div>

          <div class="sidebar-section">
            <p class="sidebar-label">{t.stats}</p>
            <ul class="sidebar-stats">
              <li><span class="stat-key">{t.license}</span><span class="stat-val">MIT</span></li>
              <li><span class="stat-key">{t.python}</span><span class="stat-val">3.10+</span></li>
              <li><span class="stat-key">{t.version}</span><span class="stat-val">0.1.8</span></li>
              <li><span class="stat-key">{t.status}</span><span class="stat-val status-beta">Beta</span></li>
              <li><span class="stat-key">{t.deps}</span><span class="stat-val">0 (base)</span></li>
            </ul>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="main-content">
        <div class="content-inner">
          <slot />
        </div>
      </main>
    </div>

    <!-- Search Modal -->
    <div class="search-modal-backdrop" id="searchModal" style="display: none;">
      <div class="search-modal">
        <div class="search-header">
          <input type="text" id="searchInput" placeholder={isSpanish ? "Buscar en la documentación..." : "Search documentation..."} autocomplete="off" />
          <button class="search-close" id="searchClose">✕</button>
        </div>
        <div class="search-results" id="searchResults"></div>
        <div class="search-footer">
          <span>↑↓ {isSpanish ? "Navegar" : "Navigate"}</span>
          <span>↵ {isSpanish ? "Seleccionar" : "Select"}</span>
          <span>esc {isSpanish ? "Cerrar" : "Close"}</span>
        </div>
      </div>
    </div>

    <script define:vars={{ isSpanish }}>
      // BroadcastChannel warm routing helper
      function sendToPlayground(rawCode, fromUrl = "") {
        if (!rawCode) return;
        
        const bc = new BroadcastChannel('physure-playground');
        let playgroundResponded = false;
        
        const bcListener = (e) => {
          if (e.data && e.data.type === 'playground-pong') {
            playgroundResponded = true;
            bc.postMessage({ type: 'playground-load-code', code: rawCode });
          }
        };
        bc.addEventListener('message', bcListener);
        
        bc.postMessage({ type: 'playground-ping' });
        
        setTimeout(() => {
          bc.removeEventListener('message', bcListener);
          bc.close();
          
          if (playgroundResponded) {
            window.open('', 'physure_playground');
          } else {
            const encoded = btoa(unescape(encodeURIComponent(rawCode)));
            const isSp = window.location.pathname.startsWith('/es');
            const targetUrl = `${isSp ? '/es' : ''}/playground?code=${encodeURIComponent(encoded)}` + (fromUrl ? `&from=${encodeURIComponent(fromUrl)}` : '');
            window.open(targetUrl, 'physure_playground');
          }
        }, 100);
      }

      // Mobile menu toggle
      const menuToggle = document.getElementById('menuToggle');
      const sidebar = document.getElementById('sidebar');
      menuToggle?.addEventListener('click', () => {
        sidebar?.classList.toggle('open');
      });

      // Copy buttons
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const text = btn.getAttribute('data-copy') || '';
          navigator.clipboard.writeText(text).then(() => {
            const original = btn.innerHTML;
            btn.innerHTML = '✓';
            setTimeout(() => { btn.innerHTML = original; }, 2000);
          });
        });
      });

      // Run in Playground link interception
      document.querySelectorAll('.run-in-playground').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          
          const activeStepPane = link.closest('.step-pane');
          const activeTutorialContent = link.closest('.tutorial-content');
          
          let rawCode = "";
          
          if (activeStepPane && activeTutorialContent) {
            // This is a step inside a tutorial wizard!
            // Gather all code blocks up to the current step to avoid NameError
            const currentStep = parseInt(activeStepPane.getAttribute('data-step'));
            const allSteps = Array.from(activeTutorialContent.querySelectorAll('.step-pane'));
            
            // Sort steps by number to ensure correct execution order
            allSteps.sort((a, b) => parseInt(a.getAttribute('data-step')) - parseInt(b.getAttribute('data-step')));
            
            const codes = [];
            for (const stepPane of allSteps) {
              const stepNum = parseInt(stepPane.getAttribute('data-step'));
              if (stepNum <= currentStep) {
                const codeEl = stepPane.querySelector('pre code');
                if (codeEl) {
                  codes.push(codeEl.textContent.trim());
                }
              }
            }
            rawCode = codes.join('\n\n# --- Continuation of steps ---\n\n');
          } else {
            // This is a standalone example section (not in a wizard)
            const container = link.closest('section') || link.closest('.api-card') || link.closest('.demo-card') || document;
            const codeEl = container.querySelector('pre code');
            if (codeEl) {
              rawCode = codeEl.textContent;
            }
          }
          
          if (rawCode) {
            // Build the backlink to resume state
            let fromUrl = window.location.pathname;
            if (activeStepPane && activeTutorialContent) {
              const step = activeStepPane.getAttribute('data-step');
              const tutorialId = activeTutorialContent.id.replace('Tutorial', ''); // e.g. "sensor"
              fromUrl += `?tutorial=${tutorialId}&step=${step}`;
            }
            sendToPlayground(rawCode, fromUrl);
          }
        });
      });

      // Code block copy and run buttons
      document.querySelectorAll('pre').forEach(pre => {
        // Do not add buttons inside the playground editor/console itself
        if (window.location.pathname.includes('/playground')) return;

        pre.style.position = 'relative';

        // 1. Copy Button
        const copyBtn = document.createElement('button');
        copyBtn.className = 'pre-copy-btn';
        copyBtn.title = isSpanish ? 'Copiar código' : 'Copy code';
        copyBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
        pre.appendChild(copyBtn);
        copyBtn.addEventListener('click', () => {
          const code = pre.querySelector('code')?.textContent || '';
          navigator.clipboard.writeText(code).then(() => {
            copyBtn.innerHTML = '✓';
            setTimeout(() => {
              copyBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
            }, 2000);
          });
        });

        // 2. Run Button
        const runBtn = document.createElement('button');
        runBtn.className = 'pre-run-btn';
        runBtn.title = isSpanish ? 'Ejecutar en Playground' : 'Run in Playground';
        runBtn.innerHTML = '<svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" style="margin-right:3px; display:inline-block; vertical-align:middle;"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>' + (isSpanish ? 'Ejecutar' : 'Run');
        pre.appendChild(runBtn);
        runBtn.addEventListener('click', () => {
          const code = pre.querySelector('code')?.textContent || '';
          sendToPlayground(code, window.location.pathname);
        });
      });

      // Search database
      const searchIndex = [
        // English
        { title: "Overview / Home", url: "/", excerpt: "Intro to physure unit-aware physics calculations.", lang: "en" },
        { title: "What is physure?", url: "/#what-is-physure", excerpt: "Under-the-hood differences with Pint.", lang: "en" },
        { title: "Honest Performance", url: "/#honest-performance", excerpt: "Eager mode speed vs compiled graph optimization.", lang: "en" },
        { title: "Installation", url: "/install", excerpt: "Install with pip or uv for base, native Rust or all backends.", lang: "en" },
        { title: "Building from source", url: "/install#building-from-source", excerpt: "Compiling maturin Rust core from source.", lang: "en" },
        { title: "Quick Start", url: "/quickstart", excerpt: "Create first quantity, convert, uncertainty propagation.", lang: "en" },
        { title: "Grammar notation", url: "/quickstart#grammar-notation", excerpt: "physure grammar syntax in Python interpreter.", lang: "en" },
        { title: "Terminal calculator", url: "/quickstart#terminal-calculator", excerpt: "CLI options and interactive REPL.", lang: "en" },
        { title: "User Guide", url: "/guide", excerpt: "Full guide covering physical quantities and unit singletons.", lang: "en" },
        { title: "Absolute vs Delta Temperature", url: "/guide#arithmetic", excerpt: "Celsius and Fahrenheit offsets versus delta units.", lang: "en" },
        { title: "Trigonometric & Transcendentals", url: "/guide#transcendentals", excerpt: "Dimensionless sine, exp, log, tanh on quantities.", lang: "en" },
        { title: "Uncertainty Propagation", url: "/guide#uncertainty", excerpt: "Taylor series, Monte Carlo, and Unscented modes.", lang: "en" },
        { title: "Correlated Covariance Store", url: "/guide#covariance", excerpt: "UUID lineages and sparse matrix propagation.", lang: "en" },
        { title: "JAX Stateless Functional API", url: "/guide#functional", excerpt: "FunctionalState pytree tracking for JAX JIT.", lang: "en" },
        { title: "JIT Tracing & Zero-Overhead", url: "/guide#jit", excerpt: "torch.compile dispatching and raw GPU kernels.", lang: "en" },
        { title: "SymPy Symbolic Math", url: "/guide#symbolic", excerpt: "SymbolicQuantity, Equation solving, diff and integrate.", lang: "en" },
        { title: "Native Symbolic Math Engine", url: "/guide#native-symbolic", excerpt: "Zero-dependency algebraic simplification and exact derivatives in Rust/Python fallback.", lang: "en" },
        { title: "Chemistry & Reaction Tracking", url: "/guide#chemistry", excerpt: "Substance-aware mass-to-mole conversions, reaction balancing, and yields.", lang: "en" },
        { title: "AOT Physics Compiler", url: "/guide#aot-compiler", excerpt: "Bakes unit-checked functions into raw-float kernels with zero overhead.", lang: "en" },
        { title: "Symbolic Regression", url: "/guide#symbolic-regression", excerpt: "Fits dimensionally consistent formulas to datasets using genetic programming.", lang: "en" },
        { title: "Unit-Aware Plotting", url: "/guide#plotting", excerpt: "Built-in plotting utilities with automatic units, error bars, and covariance maps.", lang: "en" },
        { title: "Pandas Accessor", url: "/guide#pandas", excerpt: "Series extension array and custom physure[unit] type.", lang: "en" },
        { title: "Serialization (IO)", url: "/guide#io", excerpt: "HDF5 dataset attributes and xarray accessories.", lang: "en" },
        { title: "API Reference", url: "/api", excerpt: "Quantity properties and methods lookup table.", lang: "en" },
        { title: "Module functions", url: "/api#module-functions", excerpt: "system_context, propagation_mode, jit, save_state.", lang: "en" },
        { title: "Exceptions", url: "/api#exceptions", excerpt: "IncompatibleUnitsError, UnknownUnitError, ConversionError.", lang: "en" },
        { title: "Examples", url: "/examples", excerpt: "Kinematics, Force, Pressure, Temperature, Uncertainty, NumPy, SymPy, JIT.", lang: "en" },
        { title: "CLI & REPL Details", url: "/cli", excerpt: "physure grammar statements and script piping.", lang: "en" },
        { title: "VS Code Extension", url: "/vscode", excerpt: "Install and configure the physure Meta-Lang (MKML) editor extension.", lang: "en" },
        { title: "Changelog", url: "/changelog", excerpt: "Timeline release notes from v0.1.0 to v0.1.8.", lang: "en" },

        // Spanish
        { title: "Inicio", url: "/es/", excerpt: "Introducción a los cálculos físicos con unidades en Python.", lang: "es" },
        { title: "Rendimiento Real", url: "/es/#honest-performance", excerpt: "Velocidad eager vs optimización con compilación de grafos.", lang: "es" },
        { title: "Instalación", url: "/es/install", excerpt: "Instalación por pip, uv, extras native, numpy, torch, jax.", lang: "es" },
        { title: "Compilar desde código fuente", url: "/es/install#building-from-source", excerpt: "Compilación de maturin Rust core desde repositorio.", lang: "es" },
        { title: "Guía Rápida", url: "/es/quickstart", excerpt: "Uso básico de la factoría Q_, conversiones y REPL.", lang: "es" },
        { title: "Calculadora de consola", url: "/es/quickstart#terminal-calculator", excerpt: "CLI de physure para evaluación directa.", lang: "es" },
        { title: "Guía de Usuario", url: "/es/guide", excerpt: "Completa guía de arquitectura de physure.", lang: "es" },
        { title: "Temperaturas Absolutas vs Delta", url: "/es/guide#arithmetic", excerpt: "Diferencia de temperatura en offsets Celsius/Fahrenheit.", lang: "es" },
        { title: "Funciones Trascendentales", url: "/es/guide#transcendentals", excerpt: "Seno, coseno, exp, log en cantidades físicas.", lang: "es" },
        { title: "Propagación de Incertidumbre", url: "/es/guide#uncertainty", excerpt: "Modos Monte Carlo y Transformada Unscented.", lang: "es" },
        { title: "Matriz de Covarianza Global", url: "/es/guide#covariance", excerpt: "Almacén de covarianza y transformaciones afines.", lang: "es" },
        { title: "JAX API Funcional sin Estado", url: "/es/guide#functional", excerpt: "Uso de FunctionalState como pytree para JAX JIT.", lang: "es" },
        { title: "Compilación JIT y Trazado", url: "/es/guide#jit", excerpt: "Integración torch.compile y kernels nativos en GPU.", lang: "es" },
        { title: "Matemática Simbólica SymPy", url: "/es/guide#symbolic", excerpt: "SymbolicQuantity, resolución de ecuaciones, derivadas e integrales.", lang: "es" },
        { title: "Matemática Simbólica Nativa", url: "/es/guide#native-symbolic", excerpt: "Simplificación algebraica y derivadas exactas sin dependencias en Rust.", lang: "es" },
        { title: "Química y Reacciones", url: "/es/guide#chemistry", excerpt: "Conversión de masa a moles por especie, balanceo de reacciones y rendimiento.", lang: "es" },
        { title: "Compilador AOT de Física", url: "/es/guide#aot-compiler", excerpt: "Compila funciones validadas a código sin overhead en ejecución.", lang: "es" },
        { title: "Regresión Simbólica", url: "/es/guide#symbolic-regression", excerpt: "Ajuste de fórmulas dimensionalmente consistentes mediante programación genética.", lang: "es" },
        { title: "Gráficos con Unidades", url: "/es/guide#plotting", excerpt: "Visualizaciones integradas con formateo de unidades y covarianza.", lang: "es" },
        { title: "Pandas e Integraciones", url: "/es/guide#pandas", excerpt: "Series extendidas y tipo physure[m/s].", lang: "es" },
        { title: "Serialización (IO)", url: "/es/guide#io", excerpt: "Formatos HDF5 y accessor para DataArray de xarray.", lang: "es" },
        { title: "Referencia API", url: "/es/api", excerpt: "Tabla de referencia de Quantity, propiedades y métodos.", lang: "es" },
        { title: "Funciones de Módulo", url: "/es/api#module-functions", excerpt: "system_context, propagation_mode, jit, save_state.", lang: "es" },
        { title: "Excepciones", url: "/es/api#exceptions", excerpt: "IncompatibleUnitsError, UnknownUnitError, ConversionError.", lang: "es" },
        { title: "Ejemplos Prácticos", url: "/es/examples", excerpt: "Cinemática, Fuerza, Presión, Temperatura, Péndulo, NumPy, JIT.", lang: "es" },
        { title: "CLI y REPL detalles", url: "/es/cli", excerpt: "Gramática physure y ejecución por tuberías.", lang: "es" },
        { title: "Extensión VS Code", url: "/es/vscode", excerpt: "Instalación y configuración de la extensión de editor para physure Meta-Lang (MKML).", lang: "es" },
        { title: "Historial", url: "/es/changelog", excerpt: "Notas de lanzamiento de la versión v0.1.0 a la v0.1.8.", lang: "es" },
      ];

      const currentLang = isSpanish ? "es" : "en";
      const searchModal = document.getElementById('searchModal');
      const searchTrigger = document.getElementById('searchTrigger');
      const searchClose = document.getElementById('searchClose');
      const searchInput = document.getElementById('searchInput');
      const searchResults = document.getElementById('searchResults');

      let activeIndex = -1;

      function openSearch() {
        searchModal.style.display = 'flex';
        searchInput.focus();
        document.body.style.overflow = 'hidden';
      }

      function closeSearch() {
        searchModal.style.display = 'none';
        searchInput.value = '';
        searchResults.innerHTML = '';
        activeIndex = -1;
        document.body.style.overflow = '';
      }

      searchTrigger?.addEventListener('click', openSearch);
      searchClose?.addEventListener('click', closeSearch);

      // Backdrop close
      searchModal?.addEventListener('click', (e) => {
        if (e.target === searchModal) {
          closeSearch();
        }
      });

      // ESC key close & Ctrl+K open
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && searchModal.style.display === 'flex') {
          closeSearch();
        }
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          openSearch();
        }
      });

      // Realtime search
      searchInput?.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase().trim();
        if (!query) {
          searchResults.innerHTML = '';
          return;
        }

        const filtered = searchIndex
          .filter(item => item.lang === currentLang)
          .filter(item => item.title.toLowerCase().includes(query) || item.excerpt.toLowerCase().includes(query))
          .slice(0, 8);

        searchResults.innerHTML = filtered.map((item, idx) => `
          <a href="${item.url}" class="search-result-item ${idx === 0 ? 'selected' : ''}">
            <div class="result-title">${item.title}</div>
            <div class="result-excerpt">${item.excerpt}</div>
          </a>
        `).join('');

        activeIndex = filtered.length > 0 ? 0 : -1;
      });

      // Keyboard navigation in results
      searchInput?.addEventListener('keydown', (e) => {
        const items = searchResults.querySelectorAll('.search-result-item');
        if (items.length === 0) return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          items[activeIndex]?.classList.remove('selected');
          activeIndex = (activeIndex + 1) % items.length;
          items[activeIndex].classList.add('selected');
          items[activeIndex].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          items[activeIndex]?.classList.remove('selected');
          activeIndex = (activeIndex - 1 + items.length) % items.length;
          items[activeIndex].classList.add('selected');
          items[activeIndex].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (activeIndex >= 0 && items[activeIndex]) {
            items[activeIndex].click();
          }
        }
      });
    </script>
  </body>
</html>

