---
export interface Props {
  title: string;
  description?: string;
  activeSection?: string;
}

const { title, description = "MeasureKit — Unit-aware physics computation for Python", activeSection = "" } = Astro.props;

const SITE = Astro.site?.href.replace(/\/$/, "") ?? "";
const OG_IMAGE = SITE + "/logo.jpg";

const navItems = [
  { label: "Overview", href: "/", section: "overview", icon: "🏠" },
  { label: "Installation", href: "/install", section: "install", icon: "📦" },
  { label: "Quick Start", href: "/quickstart", section: "quickstart", icon: "⚡" },
  { label: "User Guide", href: "/guide", section: "guide", icon: "📖" },
  { label: "API Reference", href: "/api", section: "api", icon: "🔧" },
  { label: "Examples", href: "/examples", section: "examples", icon: "🧪" },
  { label: "CLI & REPL", href: "/cli", section: "cli", icon: "💻" },
  { label: "Changelog", href: "/changelog", section: "changelog", icon: "📋" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — MeasureKit Docs</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={SITE + Astro.url.pathname} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title + " — MeasureKit Docs"} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={SITE + Astro.url.pathname} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta name="twitter:card" content="summary" />
  </head>

  <body>
    <!-- Top Navigation Bar -->
    <header class="topbar">
      <div class="topbar-inner">
        <a href="/" class="brand">
          <img src="/logo.jpg" alt="MeasureKit" width="32" height="32" class="brand-logo" />
          <span class="brand-name">MeasureKit</span>
          <span class="brand-badge">v0.1.8</span>
        </a>
        <nav class="topbar-nav">
          <a href="https://github.com/Alexisrx96/measurekit" target="_blank" rel="noopener" class="topbar-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="https://pypi.org/project/measurekit/" target="_blank" rel="noopener" class="topbar-link">PyPI</a>
        </nav>
        <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu">☰</button>
      </div>
    </header>

    <div class="layout">
      <!-- Sidebar -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-inner">
          <div class="sidebar-section">
            <p class="sidebar-label">Navigation</p>
            <ul class="sidebar-nav">
              {navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class={`sidebar-link ${activeSection === item.section ? "active" : ""}`}
                  >
                    <span class="nav-icon">{item.icon}</span>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class="sidebar-section">
            <p class="sidebar-label">Install</p>
            <div class="install-box">
              <code>pip install measurekit</code>
              <button class="copy-btn" data-copy="pip install measurekit" title="Copy">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              </button>
            </div>
          </div>

          <div class="sidebar-section">
            <p class="sidebar-label">Stats</p>
            <ul class="sidebar-stats">
              <li><span class="stat-key">License</span><span class="stat-val">MIT</span></li>
              <li><span class="stat-key">Python</span><span class="stat-val">3.10+</span></li>
              <li><span class="stat-key">Version</span><span class="stat-val">0.1.8</span></li>
              <li><span class="stat-key">Status</span><span class="stat-val status-beta">Beta</span></li>
              <li><span class="stat-key">Deps</span><span class="stat-val">0 (base)</span></li>
            </ul>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="main-content">
        <div class="content-inner">
          <slot />
        </div>
      </main>
    </div>

    <script>
      // Mobile menu toggle
      const menuToggle = document.getElementById('menuToggle');
      const sidebar = document.getElementById('sidebar');
      menuToggle?.addEventListener('click', () => {
        sidebar?.classList.toggle('open');
      });

      // Copy buttons
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const text = btn.getAttribute('data-copy') || '';
          navigator.clipboard.writeText(text).then(() => {
            const original = btn.innerHTML;
            btn.innerHTML = '✓';
            setTimeout(() => { btn.innerHTML = original; }, 2000);
          });
        });
      });

      // Code block copy buttons
      document.querySelectorAll('pre').forEach(pre => {
        const btn = document.createElement('button');
        btn.className = 'pre-copy-btn';
        btn.title = 'Copy code';
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
        pre.style.position = 'relative';
        pre.appendChild(btn);
        btn.addEventListener('click', () => {
          const code = pre.querySelector('code')?.textContent || '';
          navigator.clipboard.writeText(code).then(() => {
            btn.innerHTML = '✓';
            setTimeout(() => {
              btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
            }, 2000);
          });
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0a0d13;
    --bg2: #0f1318;
    --panel: #141920;
    --panel2: #1a2030;
    --text: #e2e8f0;
    --text2: #94a3b8;
    --text3: #64748b;
    --accent: #6366f1;
    --accent2: #818cf8;
    --accent-glow: rgba(99, 102, 241, 0.15);
    --green: #10b981;
    --yellow: #f59e0b;
    --red: #ef4444;
    --border: #1e2535;
    --border2: #252d3d;
    --radius: 8px;
    --radius-lg: 12px;
    --shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    --topbar-h: 56px;
    --sidebar-w: 260px;
    color-scheme: dark;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 15px;
    line-height: 1.7;
    min-height: 100vh;
  }

  /* ── Topbar ── */
  .topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--topbar-h);
    background: rgba(10, 13, 19, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
  }
  .topbar-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 100%;
    padding: 0 1.5rem;
  }
  .brand {
    display: flex; align-items: center; gap: 0.5rem;
    text-decoration: none; color: var(--text); flex-shrink: 0;
  }
  .brand-logo { border-radius: 6px; }
  .brand-name { font-weight: 700; font-size: 1rem; }
  .brand-badge {
    background: var(--panel2);
    color: var(--text2);
    border: 1px solid var(--border2);
    border-radius: 20px;
    padding: 0.1em 0.5em;
    font-size: 0.7rem;
    font-weight: 500;
  }
  .topbar-nav {
    display: flex; align-items: center; gap: 1rem;
    margin-left: auto;
  }
  .topbar-link {
    display: flex; align-items: center; gap: 0.35rem;
    color: var(--text2); text-decoration: none;
    font-size: 0.875rem; font-weight: 500;
    transition: color 0.2s;
  }
  .topbar-link:hover { color: var(--accent2); }
  .menu-toggle {
    display: none; background: none; border: none;
    color: var(--text); font-size: 1.2rem; cursor: pointer;
    margin-left: auto;
  }

  /* ── Layout ── */
  .layout {
    display: flex;
    padding-top: var(--topbar-h);
    min-height: 100vh;
  }

  /* ── Sidebar ── */
  .sidebar {
    position: fixed;
    top: var(--topbar-h); bottom: 0; left: 0;
    width: var(--sidebar-w);
    overflow-y: auto;
    border-right: 1px solid var(--border);
    background: var(--bg2);
    scrollbar-width: thin;
    scrollbar-color: var(--border2) transparent;
    z-index: 50;
  }
  .sidebar-inner { padding: 1.5rem 1rem; }
  .sidebar-section { margin-bottom: 1.75rem; }
  .sidebar-label {
    color: var(--text3); font-size: 0.7rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
    margin-bottom: 0.5rem; padding: 0 0.5rem;
  }
  .sidebar-nav { list-style: none; }
  .sidebar-link {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.45rem 0.75rem;
    border-radius: var(--radius);
    color: var(--text2); text-decoration: none;
    font-size: 0.875rem; font-weight: 450;
    transition: all 0.15s;
  }
  .sidebar-link:hover { background: var(--panel); color: var(--text); }
  .sidebar-link.active {
    background: var(--accent-glow);
    color: var(--accent2);
    font-weight: 500;
  }
  .nav-icon { font-size: 0.85rem; }

  .install-box {
    display: flex; align-items: center; justify-content: space-between;
    background: var(--panel);
    border: 1px solid var(--border2);
    border-radius: var(--radius);
    padding: 0.6rem 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--accent2);
  }
  .copy-btn {
    background: none; border: none; cursor: pointer;
    color: var(--text3); transition: color 0.2s;
    display: flex; align-items: center;
  }
  .copy-btn:hover { color: var(--text); }

  .sidebar-stats { list-style: none; }
  .sidebar-stats li {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.3rem 0.5rem;
    border-radius: 4px;
    font-size: 0.8rem;
  }
  .stat-key { color: var(--text3); }
  .stat-val { color: var(--text2); font-weight: 500; }
  .status-beta {
    background: rgba(245, 158, 11, 0.15);
    color: var(--yellow);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-size: 0.72rem;
  }

  /* ── Main Content ── */
  .main-content {
    margin-left: var(--sidebar-w);
    flex: 1;
    min-width: 0;
  }
  .content-inner {
    max-width: 900px;
    padding: 2.5rem 2.5rem 5rem;
  }

  /* ── Typography ── */
  h1 { font-size: 2.25rem; font-weight: 700; line-height: 1.2; margin-bottom: 0.75rem; color: var(--text); }
  h2 { font-size: 1.5rem; font-weight: 600; line-height: 1.3; margin: 2.5rem 0 0.75rem; color: var(--text); border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
  h3 { font-size: 1.15rem; font-weight: 600; margin: 1.75rem 0 0.5rem; color: var(--text); }
  h4 { font-size: 1rem; font-weight: 600; margin: 1.25rem 0 0.35rem; color: var(--text2); }
  p { margin-bottom: 1rem; color: var(--text2); }
  a { color: var(--accent2); text-decoration: none; }
  a:hover { text-decoration: underline; }
  ul, ol { padding-left: 1.5rem; margin-bottom: 1rem; color: var(--text2); }
  li { margin-bottom: 0.3rem; }
  strong { color: var(--text); font-weight: 600; }

  /* ── Code ── */
  pre {
    background: var(--panel);
    border: 1px solid var(--border2);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1rem 0 1.5rem;
    font-size: 0.855rem;
    line-height: 1.65;
    position: relative;
  }
  code {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.875em;
  }
  p code, li code, td code {
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    color: var(--accent2);
    font-size: 0.85em;
  }

  .pre-copy-btn {
    position: absolute; top: 0.75rem; right: 0.75rem;
    background: var(--panel2); border: 1px solid var(--border2);
    border-radius: 4px; padding: 0.3rem 0.4rem;
    color: var(--text3); cursor: pointer;
    opacity: 0; transition: opacity 0.2s, color 0.2s;
    display: flex; align-items: center;
  }
  pre:hover .pre-copy-btn { opacity: 1; }
  .pre-copy-btn:hover { color: var(--text); }

  /* ── Cards ── */
  .card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: var(--border2); }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin: 1rem 0;
  }

  /* ── Badges / Callouts ── */
  .callout {
    border-radius: var(--radius);
    padding: 0.875rem 1.25rem;
    margin: 1rem 0;
    border-left: 3px solid;
    font-size: 0.9rem;
  }
  .callout p { margin: 0; }
  .callout-info { background: rgba(99, 102, 241, 0.08); border-color: var(--accent); }
  .callout-warning { background: rgba(245, 158, 11, 0.08); border-color: var(--yellow); }
  .callout-danger { background: rgba(239, 68, 68, 0.08); border-color: var(--red); }
  .callout-success { background: rgba(16, 185, 129, 0.08); border-color: var(--green); }

  /* ── Tables ── */
  table { width: 100%; border-collapse: collapse; margin: 1rem 0 1.5rem; font-size: 0.875rem; }
  th { background: var(--panel2); color: var(--text); font-weight: 600; text-align: left; padding: 0.6rem 1rem; border-bottom: 1px solid var(--border2); }
  td { padding: 0.55rem 1rem; border-bottom: 1px solid var(--border); color: var(--text2); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--panel); }

  /* ── Badges ── */
  .badge {
    display: inline-block;
    padding: 0.15em 0.55em;
    border-radius: 20px;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .badge-blue { background: rgba(99,102,241,0.2); color: var(--accent2); }
  .badge-green { background: rgba(16,185,129,0.2); color: var(--green); }
  .badge-yellow { background: rgba(245,158,11,0.2); color: var(--yellow); }
  .badge-gray { background: var(--panel2); color: var(--text3); }

  /* ── Page header ── */
  .page-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .page-header .kicker {
    color: var(--accent2); font-size: 0.8rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .page-header p { font-size: 1.05rem; color: var(--text2); margin-bottom: 0; }

  /* ── Steps ── */
  .steps { counter-reset: step; list-style: none; padding: 0; }
  .steps li {
    counter-increment: step;
    display: flex; gap: 1rem;
    margin-bottom: 1.75rem;
    position: relative;
  }
  .steps li::before {
    content: counter(step);
    flex-shrink: 0;
    width: 28px; height: 28px;
    background: var(--accent-glow);
    border: 1px solid var(--accent);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--accent2); font-size: 0.78rem; font-weight: 700;
    margin-top: 0.1rem;
  }

  /* ── Tabs ── */
  .tabs { margin: 1.5rem 0; }
  .tab-list { display: flex; gap: 0; border-bottom: 1px solid var(--border); margin-bottom: 0; }
  .tab-btn {
    padding: 0.6rem 1.2rem;
    background: none; border: none; cursor: pointer;
    color: var(--text3); font-size: 0.875rem; font-weight: 500;
    border-bottom: 2px solid transparent; margin-bottom: -1px;
    font-family: inherit; transition: all 0.15s;
  }
  .tab-btn.active { color: var(--accent2); border-bottom-color: var(--accent2); }
  .tab-btn:hover:not(.active) { color: var(--text2); }
  .tab-panel { display: none; padding: 0; }
  .tab-panel.active { display: block; }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .menu-toggle { display: flex; align-items: center; }
    .topbar-nav { display: none; }
    .sidebar {
      transform: translateX(-100%);
      transition: transform 0.25s;
    }
    .sidebar.open { transform: translateX(0); }
    .main-content { margin-left: 0; }
    .content-inner { padding: 1.5rem 1rem 4rem; }
    h1 { font-size: 1.75rem; }
  }
</style>
